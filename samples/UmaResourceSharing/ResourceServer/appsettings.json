{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "resource": "uma-resource-server",
    "credentials": {
      "secret": "uma-resource-server-secret"
    },
    "ssl-required": "none",
    "verify-token-audience": true,
    "confidential-port": 0
  }
}
