<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - UMA Razor Pages</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" asp-page="/Index">UMA Razor Pages</a>
            <div class="navbar-nav me-auto">
                <a class="nav-link" asp-page="/Index">Home</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="nav-link" asp-page="/Documents/Index">Documents</a>
                    <a class="nav-link" asp-page="/Permissions/Index">Permissions</a>
                }
            </div>
            <div class="navbar-nav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="nav-link text-light">@User.Identity.Name</span>
                    <form method="post" action="/authentication/logout">
                        <button type="submit" class="btn btn-outline-light btn-sm mt-1">Logout</button>
                    </form>
                }
                else
                {
                    <a class="nav-link" href="/authentication/login">Login</a>
                }
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
